# Backend — copy this to backend/.env and fill in values

# Railway MySQL (injected automatically by the Railway MySQL plugin)
MYSQL_URL=mysql://user:password@host:port/dbname

# Auth — set these in Railway Variables
JWT_SECRET=some_long_random_secret_string
ADMIN_PASSWORD=your_chosen_password

# Port (Railway sets this automatically)
PORT=3001

# Vercel frontend URL for CORS (set after deploying the frontend)
FRONTEND_URL=https://tt-judgments.vercel.app
